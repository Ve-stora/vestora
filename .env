# ─────────────────────────────────────────────────────────────────────────────
# Vestora — Environment Configuration
# Copy to .env and fill in your values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development              # development | production
SECRET_KEY=change-this-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 24 hours

# ── Database ─────────────────────────────────────────────────────────────────
# Development (SQLite — no setup needed):
DATABASE_URL=sqlite+aiosqlite:///./vestora.db

# Production (PostgreSQL — matches docker-compose.yml):
# DATABASE_URL=postgresql+asyncpg://vestora:vestora_dev@db:5432/vestora

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com

# ── LLM — Analytics Engine ───────────────────────────────────────────────────
# Groq is free and fast. Get a key at https://console.groq.com
# Alternatively use any OpenAI-compatible endpoint.
LLM_API_KEY=                              # required for /api/ai/analytics
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama3-8b-8192

# OpenAI alternative:
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# ── Data Sources ─────────────────────────────────────────────────────────────
NSE_DATA_URL=https://afx.kwayisi.org/nse/
USE_DATA_URL=https://afx.kwayisi.org/use/

# ── Cache TTLs (seconds) ──────────────────────────────────────────────────────
MARKET_DATA_TTL=86400       # 24h — NSE data is end-of-day, daily refresh is correct
ANALYTICS_CACHE_TTL=3600    # 1h
API_RESPONSE_TTL=900        # 15min

# ── Optional: Redis (production caching) ─────────────────────────────────────
# Uncomment to enable Redis instead of in-memory cache.
# The cache.py module must be updated to use redis-py async client.
# REDIS_URL=redis://localhost:6379/0

# ── ML Model Paths ────────────────────────────────────────────────────────────
# Defaults to backend/app/ml/models/ — only override if storing models externally
# ML_MODELS_DIR=/path/to/models